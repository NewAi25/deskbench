# DeskBench — environment variables
#
# Copy this file to `.env` and fill in the keys for the providers you want to
# use. `.env` is gitignored and must NEVER be committed. Every model in
# config/models.yaml (Step 2) references one of these variables by name; the
# code reads keys from the environment only — no key ever lives in a config or
# source file.
#
# All four providers below offer a free tier sufficient for a full DeskBench
# run (see BUILD_PLAN.md section 8). You only need keys for the providers whose
# models you actually run.

# --- Google Gemini (Google AI Studio) -------------------------------------
# Free tier: https://aistudio.google.com/apikey
# Powers: gemini-flash (Gemini 1.5/2.x Flash family)
# LiteLLM provider prefix: gemini/
GEMINI_API_KEY=

# --- Groq -------------------------------------------------------------------
# Free tier: https://console.groq.com/keys
# Powers: Llama 3.x 70B and other open-weight models at high speed
# LiteLLM provider prefix: groq/
GROQ_API_KEY=

# --- Z.ai (GLM) -------------------------------------------------------------
# Free tier: https://z.ai  (GLM-4.x Flash is free)
# Powers: glm-4-flash
# LiteLLM provider prefix: openai/ against the Z.ai base URL (set in models.yaml)
ZAI_API_KEY=

# --- OpenRouter -------------------------------------------------------------
# Free tier: https://openrouter.ai/keys  (models with the `:free` suffix)
# Powers: deepseek and other community models routed for $0
# LiteLLM provider prefix: openrouter/
OPENROUTER_API_KEY=
